# ─────────────────────────────────────────────────────────────────────────────
# job_finder_v2 — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Anthropic Claude API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=

# ── JOB DISCOVERY ─────────────────────────────────────────────────────────────

# JSearch via RapidAPI — aggregates LinkedIn, Indeed, Google Jobs in one call
# Sign up free at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month. Upgrade for heavy use.
# Not required if DEV_MODE=true
JSEARCH_API_KEY=f

# ── EMAIL TRACKING (OUTLOOK) ───────────────────────────────────────────────────

# Your Microsoft/Outlook email address
OUTLOOK_EMAIL=m

# App Password (NOT your regular password — Microsoft requires App Passwords for IMAP)
# Generate at: account.microsoft.com → Security → Advanced security options → App passwords
# Leave blank to disable email tracking
OUTLOOK_APP_PASSWORD=

# Override IMAP host if using a non-Outlook Microsoft account
# IMAP_HOST=outlook.office365.com
# IMAP_PORT=993

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# OpenAI fallback (used if Anthropic is unavailable)
# OPENAI_API_KEY=sk-...

# Fernet encryption key for sensitive DB fields (email, phone, address)
# Auto-generated and saved to data/encryption.key on first run if not set
# DB_ENCRYPTION_KEY=

# ── BROWSER ───────────────────────────────────────────────────────────────────

# Set to false to watch the browser while it fills forms (useful for debugging)
HEADLESS=false

# Milliseconds between Stagehand actions (humanization delay)
SLOW_MO=50

# ── DEVELOPMENT ───────────────────────────────────────────────────────────────

# Set to true to mock browser automation and job scrapers
# Full pipeline runs without opening a real browser or calling JSearch
# LLM calls still use the real Anthropic API
DEV_MODE=true

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── APP ───────────────────────────────────────────────────────────────────────

DATA_DIR=./data
PORT=8000
